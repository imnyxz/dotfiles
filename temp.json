{
  "agent_font_size": 18.0,
  "project_panel": {
    "dock": "right"
  },
  "theme": "Kanagawa Wave - No Italics",
  "agent": {
    "dock": "left",
    "default_profile": "minimal",
    "play_sound_when_agent_done": true,
    "model_parameters": [],
    "default_model": {
      "provider": "openrouter",
      "model": "openai/gpt-oss-120b"
    },
    "version": "2"
  },
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "tab_size": 2,
  "relative_line_numbers": true,
  "ui_font_family": "JetBrainsMono Nerd Font Mono",
  "terminal": {
    "dock": "bottom",
    "font_family": "JetBrainsMono Nerd Font Mono"
  },
  "languages": {
    "Rust": {
      "tab_size": 4
    }
  }
}
